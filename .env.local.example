# Supabase — copy from your project's Settings > API page
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic (Claude) — powers the smart recipe reader and AI dinner suggestions.
# Without it, recipe import falls back to a basic text/structured-data parser.
# Get a key at https://console.anthropic.com/settings/keys
# IMPORTANT: also set this in Vercel (Project > Settings > Environment Variables)
# for it to work in production.
ANTHROPIC_API_KEY=
